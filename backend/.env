# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=susemon_db
DB_PORT=3306

# JWT Secret
JWT_SECRET=susemon_secret_key_2026_pbl_trpl412

# CORS — * untuk Flutter mobile (tidak butuh CORS restriction)
CORS_ORIGIN=*

# WebSocket — berjalan di port yang sama dengan FastAPI (3000), endpoint: /ws
# WS_PORT tidak digunakan, WebSocket ada di ws://host:3000/ws

# AI Configuration
# Sesuaikan dengan kondisi ruang server nyata
# Kelembapan ruangan ini rata-rata 77% — threshold dinaikkan
AI_THRESHOLD_TEMP=40
AI_THRESHOLD_TEMP_WARNING=35
AI_THRESHOLD_HUMIDITY=85
AI_THRESHOLD_HUM_WARNING=80
AI_PREDICTION_WINDOW=30

# MQTT Broker — lokal (Mosquitto)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USE_TLS=false
MQTT_TOPIC=sensor/data
MQTT_CLIENT_ID=susemon-fastapi
MQTT_USER=susemon
MQTT_PASS=Susemon2026mqtt

# API Key untuk gateway endpoint POST /api/sensors/data
GATEWAY_API_KEY=gw-susemon-2026-pbl412
