# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=susemon_db
DB_PORT=3306

# JWT Secret (ganti dengan string random panjang di production)
JWT_SECRET=susemon_secret_key_2026_pbl_trpl412

# CORS
CORS_ORIGIN=*

# WebSocket
WS_PORT=3001

# AI Configuration
AI_THRESHOLD_TEMP=40
AI_THRESHOLD_TEMP_WARNING=35
AI_THRESHOLD_HUMIDITY=85
AI_THRESHOLD_HUM_WARNING=80
AI_PREDICTION_WINDOW=30

# MQTT Broker — HiveMQ Cloud
MQTT_BROKER=YOUR_CLUSTER.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USE_TLS=true
MQTT_TOPIC=sensor/data
MQTT_CLIENT_ID=susemon-fastapi
MQTT_USER=your_hivemq_username
MQTT_PASS=your_hivemq_password

# API Key untuk gateway endpoint POST /api/sensors/data
GATEWAY_API_KEY=gw-susemon-2026-pbl412
