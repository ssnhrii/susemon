# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=susemon_db
DB_PORT=3306

# JWT — WAJIB diganti dengan string acak yang kuat!
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GANTI_DENGAN_STRING_ACAK_64_KARAKTER

# CORS — batasi ke origin spesifik di production
CORS_ORIGIN=*

# AI Thresholds
AI_THRESHOLD_TEMP=40
AI_THRESHOLD_TEMP_WARNING=35
AI_THRESHOLD_HUMIDITY=85
AI_THRESHOLD_HUM_WARNING=80

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=sensor/data
MQTT_CLIENT_ID=susemon-fastapi
MQTT_USER=susemon
MQTT_PASS=GANTI_PASSWORD_MQTT

# API Key gateway — WAJIB diganti!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
GATEWAY_API_KEY=GANTI_DENGAN_API_KEY_ACAK

# Data retention (hari)
DATA_RETENTION_DAYS=90
